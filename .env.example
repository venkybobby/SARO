# ─────────────────────────────────────────────────────────────────────────────
# SARO v8.0.0 — Environment Variable Reference
# Copy to .env for local development. Never commit .env.
# Production values are set in Railway dashboard / Supabase dashboard.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Supabase dashboard → Project Settings → Database → Connection string → URI
# Project ref: fktfhtygvwqlmoazmhdf  |  Region: us-west-1
DATABASE_URL=postgresql://postgres.fktfhtygvwqlmoazmhdf:[YOUR-PASSWORD]@aws-1-us-west-1.pooler.supabase.com:5432/postgres?sslmode=require

# ── Cache (Railway Redis) ─────────────────────────────────────────────────────
# Railway dashboard → Redis service → Connect → Redis URL
REDIS_URL=redis://default:<password>@redis.railway.internal:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-with-256-bit-random-hex
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── SARO Engine ───────────────────────────────────────────────────────────────
MIN_BATCH_SAMPLES=50
INCIDENT_TOP_K=10
BAYESIAN_PRIOR_ALPHA=1.0
CONFIDENCE_THRESHOLD=0.85

# ── Gunicorn workers (override default of 3) ──────────────────────────────────
# GUNICORN_WORKERS=3

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=8.0.0
ENV=production
LOG_LEVEL=info
# PORT is injected automatically by Railway — do not set manually in production

# ── Monitoring ────────────────────────────────────────────────────────────────
# Sentry dashboard → Project → Settings → Client Keys → DSN
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>

# ── Optional: Prometheus metrics ─────────────────────────────────────────────
# PROMETHEUS_ENABLED=true
# PROMETHEUS_PORT=9090

# ── CORS (comma-separated) ────────────────────────────────────────────────────
# In production set this to your Vercel domain — NOT "*"
CORS_ALLOWED_ORIGINS=https://saro.vercel.app,https://your-custom-domain.com

# ── GitHub Integration (routers/github_integration.py) ───────────────────────
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_PATH=
GITHUB_WEBHOOK_SECRET=

# ── Engine (SPEC-E1/E3/E4) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=            # Required for LLM-as-judge hybrid classifier (SPEC-E1)
LLM_CONFIDENCE_THRESHOLD=0.7  # LLM confidence threshold for flag confirmation
MAX_LLM_CALLS_PER_BATCH=200   # Cost cap: max LLM calls per audit run
BAYESIAN_PRIOR_WEIGHT=5       # Prior weight for domain calibration (SPEC-E4)

# ── SSO / SAML 2.0 (SPEC-F2) ─────────────────────────────────────────────────
SAML_SP_ENTITY_ID=https://saro.app/sp
SAML_SP_ACS_URL=https://saro.app/api/v1/sso/acs
SAML_SP_KEY=                  # SP private key (PEM, no newlines) — never commit
SAML_SP_CERT=                 # SP certificate (PEM, no newlines) — never commit

# ── Notifications / Email (SPEC-F5) ──────────────────────────────────────────
SENDGRID_API_KEY=              # Optional: email alerts for critical/high notifications

# ── Jira Cloud OAuth2 (SPEC-F3) ──────────────────────────────────────────────
JIRA_CLIENT_ID=                # Atlassian OAuth 2.0 (3LO) client ID
JIRA_CLIENT_SECRET=            # Atlassian OAuth 2.0 client secret
JIRA_REDIRECT_URI=https://saro.app/api/v1/remediation/oauth/jira/callback

# ── Board Dashboard (SPEC-FE2) ────────────────────────────────────────────────
BOARD_RISK_RED_THRESHOLD=0.7   # RAG RED if any audit score > this
BOARD_RISK_AMBER_THRESHOLD=0.4 # RAG AMBER if score > this

# ── Export ────────────────────────────────────────────────────────────────────
SARO_EXPORT_SECRET=change-this-to-a-random-secret
ALLOWED_ORIGINS=              # Comma-separated allowed CORS origins (empty = *)
